{"nodes": [{"id": "specs_2026_06_22_zerod_agency_design_spec", "label": "ZeroD Agency Website Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_zerod_agency", "label": "ZeroD Agency", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "8-18", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_color_system", "label": "Brand Color System", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "22-35", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deep green (#1A4731 / #0D2818) conveys trust and professionalism for local businesses; gold (#F59E0B) used exclusively for primary CTAs and highlights to draw attention to WhatsApp conversion action."}, {"id": "specs_typography", "label": "Typography System (Hind Siliguri + Geist)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "40-55", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hind Siliguri chosen for Bengali copy because it offers best readability on Bangladeshi mobile devices; Geist Sans for English to match Next.js project default."}, {"id": "specs_logo_design", "label": "Logo Design (ZeroD text mark)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "59-69", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SVG text mark rather than image file: D enclosed in gold circle suggests zero-to-digital loop; dark/light variant via prop avoids separate asset files."}, {"id": "specs_homepage_design", "label": "Homepage Design", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "109-192", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_hero_animations", "label": "Hero Animations Design", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "121-131", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Four CSS-only animations: staggered fade-up, breathing gradient, floating ring, and WhatsApp pulse glow. GPU-composited (transform + opacity only) \u2014 no JS execution on animation path, no external library."}, {"id": "specs_services_overview_design", "label": "Services Overview Page Design (/services)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "195-207", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_website_build_design", "label": "Website Build Service Page Design (/services/website-build)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "211-239", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_portfolio_design", "label": "Portfolio Page Design (/portfolio)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "244-257", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_pricing_design", "label": "Pricing Page Design (/pricing)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "261-288", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_contact_design", "label": "Contact Page Design (/contact)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "292-308", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_tech_decisions", "label": "Tech Stack Decisions", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "344-357", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Next.js 16 App Router already set up; Tailwind v4 + CSS variables already configured; shadcn/ui partially installed; lucide-react already a dependency; Server Actions for forms avoids extra library in v1."}, {"id": "specs_pricing_tiers", "label": "Pricing Tiers (Starter / Growth / Pro)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "178-186", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_content_placeholders", "label": "Content Placeholders (pre-launch)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "362-368", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_out_of_scope_v1", "label": "Out of Scope for v1", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "371-380", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "specs_2026_06_22_zerod_agency_design_spec", "target": "specs_zerod_agency", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-22-zerod-agency-design.md", "source_location": "8", "weight": 1.0}, {"source": "specs_2026_06_22_zerod_agency_design_spec", "target": "specs_color_system", "relation": "references", "confidence": "EXTRACTED", "confid